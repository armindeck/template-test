{
    "id_file": "template-standard.json",
    "type": "standard",
    "version": "1.0",
    "created": "2026-07-11",
    "updated": "2026-07-11",
    "enable_scripts": false,
    "containers": [
        {
            "id": "start_html",
            "label": "start html",
            "type": "start_html",
            "enabled": true,
            "render": "<!DOCTYPE html>\n<html lang=\"{{ page.language }}\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>{{ page.name }}</title>\n</head>\n<body>\n"
        },
        {
            "id": "header",
            "label": "Header",
            "type": "header",
            "enabled": true,
            "render": "<header class=\"flex space-evenly p-10\"><h1>{{ page.name }}</h1></header>"
        },
        {
            "id": "main",
            "label": "Main",
            "type": "Main",
            "enabled": true,
            "render": "<main class=\"flex space-evenly\"><div class=\"content\">{{ main }}</div></main>"
        },
        {
            "id": "footer",
            "label": "Footer",
            "type": "footer",
            "enabled": true,
            "render": "<footer class=\"flex space-evenly p-6\"><small>&copy; {{ page.year }} {{ page.name }}. Powered by {{ core.creator_name }}.</small></footer>"
        },
        {
            "id": "end_html",
            "label": "end html",
            "type": "end_html",
            "enabled": true,
            "render": "\n</body>\n</html>"
        }
    ]
}